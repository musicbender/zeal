{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "DATABASE_URL_UNPOOLED",
        "NEON_PROJECT_ID",
        "PGDATABASE",
        "PGHOST",
        "PGHOST_UNPOOLED",
        "PGPASSWORD",
        "PGUSER",
        "PORTFOLIO_API_KEY",
        "POSTGRES_DATABASE",
        "POSTGRES_HOST",
        "POSTGRES_PASSWORD",
        "POSTGRES_URL",
        "POSTGRES_URL_NON_POOLING",
        "POSTGRES_URL_NO_SSL"
      ]
    },
    "prisma:generate": {},
    "prisma:migrate": {},
    "typecheck": {},
    "lint": {},
    "test": {},
    "test:e2e": {
      "cache": false,
      "env": [
        "PORTFOLIO_BASE_URL",
        "PORTFOLIO_API_KEY",
        "POSTGRES_URL"
      ]
    },
  }
}
