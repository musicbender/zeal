{
	"$schema": "https://turborepo.com/schema.json",
	"globalDependencies": ["**/.env.*local"],
	"globalEnv": [
		"DATABASE_URL",
		"DATABASE_URL_UNPOOLED",
		"NEON_PROJECT_ID",
		"PGDATABASE",
		"PGHOST",
		"PGHOST_UNPOOLED",
		"PGPASSWORD",
		"PGUSER",
		"PORTFOLIO_API_KEY",
		"HYGRAPH_ENDPOINT",
		"PORTFOLIO_BASE_URL",
		"POSTGRES_DATABASE",
		"POSTGRES_HOST",
		"POSTGRES_PASSWORD",
		"POSTGRES_URL",
		"POSTGRES_URL_NON_POOLING",
		"POSTGRES_URL_NO_SSL",
		"FLAGS",
		"FLAGS_SECRET",
		"DISCORD_APP_ID",
		"DISCORD_BOT_TOKEN",
		"DISCORD_PUBLIC_KEY",
		"CRON_SECRET",
		"CHARGEPOINT_USERNAME",
		"CHARGEPOINT_PASSWORD",
		"CHARGEPOINT_DEVICE_ID",
		"TESLA_CLIENT_ID",
		"TESLA_CLIENT_SECRET",
		"TESLA_REFRESH_TOKEN",
		"TESLA_ENERGY_SITE_ID",
		"SOLAR_WINDOW_START",
		"SOLAR_WINDOW_END",
		"SUNKEEP_ENABLED",
		"SUNKEEP_SOE_THRESHOLD"
	],
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"]
		},
		"prisma:generate": { "cache": false },
		"prisma:migrate": {},
		"typecheck": {},
		"lint": {},
		"test": {},
		"test:e2e": {
			"cache": false
		},
		"register-commands": {
			"cache": false
		},
		"start": {
			"cache": false,
			"persistent": true
		}
	}
}
