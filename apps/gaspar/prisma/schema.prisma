datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model Sensor {
  id          String    @id @default(uuid())
  name        String
  type        String
  isActive    Boolean
  activeSince DateTime?
  room        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("sensor")
}
