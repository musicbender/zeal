[Unit]
Description=Gaspar API
After=network.target

[Service]
Type=simple
User=magus
WorkingDirectory=/home/magus/apps/actions-runner/_work/zeal/zeal/apps/gaspar
ExecStart=/usr/local/bin/node dist/main.js
EnvironmentFile=/etc/gaspar/env
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
